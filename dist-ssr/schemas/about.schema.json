{
  "version": "1.0.0",
  "kind": "olonjs-page-contract",
  "slug": "about",
  "title": "About Inkwell Journal and this collections demo",
  "description": "Inkwell Journal is a working OlonJS demo: posts and tags live as separate collections, related through keys on the post side and resolved at render time.",
  "manifestHref": "/mcp-manifests/about.json",
  "systemPrompt": "You are operating the \"About Inkwell Journal and this collections demo\" page in OlonJS Studio. Use only the declared tools and keep mutations valid against the section schema.",
  "sectionTypes": [
    "header",
    "footer",
    "page-hero",
    "content-block",
    "stats-band",
    "cta-banner"
  ],
  "sectionInstances": [
    {
      "id": "global-header",
      "type": "header",
      "scope": "global",
      "label": "header"
    },
    {
      "id": "global-footer",
      "type": "footer",
      "scope": "global",
      "label": "footer"
    },
    {
      "id": "about-hero",
      "type": "page-hero",
      "scope": "local",
      "label": "A journal that is also a diagram"
    },
    {
      "id": "about-story",
      "type": "content-block",
      "scope": "local",
      "label": "One source of truth per relation"
    },
    {
      "id": "about-stats",
      "type": "stats-band",
      "scope": "local",
      "label": "What powers the demo"
    },
    {
      "id": "about-cta",
      "type": "cta-banner",
      "scope": "local",
      "label": "See it in motion"
    }
  ],
