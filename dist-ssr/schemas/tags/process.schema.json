    "header",
    "footer",
    "tag-detail",
    "tag-posts",
    "cta-banner"
  ],
  "sectionInstances": [
    {
      "id": "global-header",
      "type": "header",
      "scope": "global",
      "label": "header"
    },
    {
      "id": "global-footer",
      "type": "footer",
      "scope": "global",
      "label": "footer"
    },
    {
      "id": "tag-detail-head",
      "type": "tag-detail",
      "scope": "local",
      "label": "tag-detail"
    },
    {
      "id": "tag-detail-posts",
      "type": "tag-posts",
      "scope": "local",
      "label": "Posts on this topic"
    },
    {
      "id": "tag-detail-cta",
      "type": "cta-banner",
      "scope": "local",
      "label": "Explore another thread"
    }
  ],
