{
  "version": "1.0.0",
  "kind": "olonjs-page-contract",
  "slug": "tags/process",
  "title": "Topic — Inkwell Journal posts by tag",
  "description": "A single topic from the tags collection, with every matching essay computed live by filtering the posts collection on the current tag key.",
  "manifestHref": "/mcp-manifests/tags/process.json",
  "systemPrompt": "You are operating the \"Topic — Inkwell Journal posts by tag\" page in OlonJS Studio. Use only the declared tools and keep mutations valid against the section schema.",
